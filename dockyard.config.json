{
  "port": 4321,
  "socket": "auto",
  "auth": {
    "mode": "none"
  },
  "branding": {
    "name": "Dockyard",
    "accent": "#0E7C66",
    "favicon": "🚢"
  },
  "ui": {
    "default_view": "compose",
    "default_theme": "auto",
    "refresh_ms": 2000,
    "logs_tail_lines": 200,
